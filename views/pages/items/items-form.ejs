<h1>New Item</h1>
<a href="/" class="button">Back</a>
<form method="POST" action="/items">
  <div class="form-group">
    <label for="itemName">Item Name</label>
    <input type="text" id="itemName" name="itemName"/>
  </div>
    <div class="form-group">
    <label for="itemCost">Cost</label>
    <input type="tel" id="itemCost" name="itemCost"/>
  </div>
  <div class="form-group">
    <label for="itemClass">Class</label>
    <select id="itemClass" name="itemClass">
      <option value="">--Select Class--</option>
      <% classes.forEach((cls) => { %>
        <% const { class_name, id } = cls %>
        <option value="<%= id %>"><%= class_name %></option>
      <% }) %>
    </select>
  </div>
  <% for (let i = 0; i < 5; i++) { %>
    <div class="form-group">
      <label for="stat<%= i %>">Stat</label>
      <select id="stat<%= i %>" name="stats[<%= i %>][id]">
        <option value="">-- Select Stat --</option>
        <% stats.forEach(stat => { %>
          <option value="<%= stat.id %>"><%= stat.stat_name %></option>
        <% }) %>
      </select>

      <label for="statValue<%= i %>">Value</label>
      <input type="tel" id="statValue<%= i %>" name="stats[<%= i %>][value]" min="0"/>
    </div>
  <% } %>
  <button type="submit">Submit</button>
</form>
